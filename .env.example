# Discord Bot
DISCORD_BOT_TOKEN="your_discord_bot_token"
DISCORD_CLIENT_ID="your_client_id"
DISCORD_GUILD_ID="your_guild_id"
CONTROL_CHANNEL_ID="your_channel_id"

# Aternos Credentials
ATERNOS_USERNAME="your_aternos_username"
ATERNOS_PASSWORD="your_aternos_password"
ATERNOS_SERVER_URL="https://aternos.org/server/YOUR_SERVER_ID"

# Minecraft Server (TikdiSMP)
MC_SERVER_ADDRESS="yourserverIP"
MC_SERVER_PORT="port"

# Permission IDs (comma-separated for multiple values)
OWNER_USER_IDS=""
ADMIN_USER_IDS=""
ADMIN_ROLE_IDS=""
TRUSTED_USER_IDS=""
TRUSTED_ROLE_IDS=""

# Polling Configuration
POLL_INTERVAL_SECONDS="45"

# Logging
LOG_LEVEL="info"
